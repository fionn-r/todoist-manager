# Todoist API Token
# Get this from: Todoist Settings → Integrations → Developer
TODOIST_API_TOKEN=your-api-token-here

# Timezone for date calculations (optional)
# If not set, uses the system's local timezone
# Use IANA timezone names (e.g., Australia/Eucla, Asia/Kathmandu, Pacific/Chatham)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TIMEZONE=Australia/Eucla
